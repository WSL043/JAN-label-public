{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JAN Label",
  "version": "0.3.0",
  "identifier": "com.wsl043.janlabel",
  "build": {
    "beforeDevCommand": "pnpm --dir ../admin-web dev",
    "beforeBuildCommand": "pnpm --dir ../admin-web build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../admin-web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JAN Label",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
