<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:JanLabel.WindowsShell">
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#E7EBF0" />
  <SolidColorBrush x:Key="ChromeBrush" Color="#EEF2F6" />
  <SolidColorBrush x:Key="RibbonBrush" Color="#E2E8EF" />
  <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#F4F6F8" />
  <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#1B2430" />
  <SolidColorBrush x:Key="PanelBrush" Color="#FCFDFE" />
  <SolidColorBrush x:Key="PanelEdgeBrush" Color="#C5CED8" />
  <SolidColorBrush x:Key="MutedBrush" Color="#5F6E80" />
  <SolidColorBrush x:Key="SelectionBrush" Color="#E3EDF9" />
  <SolidColorBrush x:Key="SelectionEdgeBrush" Color="#1F5EB7" />
  <SolidColorBrush x:Key="StatusBarBrush" Color="#E0E6EC" />
  <SolidColorBrush x:Key="StatusBarEdgeBrush" Color="#B8C2CC" />
  <SolidColorBrush x:Key="ShellSurfaceBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="RailBrush" Color="#F4F6F9" />
  <SolidColorBrush x:Key="RailPanelBrush" Color="#F7F9FB" />
  <SolidColorBrush x:Key="WindowEdgeBrush" Color="#C3CCD6" />
  <SolidColorBrush x:Key="AccentBrush" Color="#165DB8" />
  <SolidColorBrush x:Key="AccentSoftBrush" Color="#DCE8FA" />
  <SolidColorBrush x:Key="CriticalBrush" Color="#B44332" />
  <SolidColorBrush x:Key="SuccessBrush" Color="#2F6E46" />

  <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#607081" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
  </Style>

  <Style x:Key="RailSectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleStyle}">
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="Foreground" Value="#425365" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="MenuButtonStyle" TargetType="Button">
    <Setter Property="Margin" Value="0,0,2,0" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style x:Key="PaneBorderStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style x:Key="WorksurfaceTabControlStyle" TargetType="TabControl">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style x:Key="PaneGridSplitterStyle" TargetType="GridSplitter">
    <Setter Property="Background" Value="#D0D8E1" />
    <Setter Property="ShowsPreview" Value="True" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style x:Key="OperatorDataGridStyle" TargetType="DataGrid">
    <Setter Property="AutoGenerateColumns" Value="False" />
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="CanUserAddRows" Value="False" />
    <Setter Property="CanUserDeleteRows" Value="False" />
    <Setter Property="CanUserResizeRows" Value="False" />
    <Setter Property="HeadersVisibility" Value="Column" />
    <Setter Property="SelectionMode" Value="Single" />
    <Setter Property="SelectionUnit" Value="FullRow" />
    <Setter Property="AlternatingRowBackground" Value="#F7FAFD" />
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="BorderBrush" Value="#CDD6DF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="RowHeaderWidth" Value="0" />
    <Setter Property="Margin" Value="0,8,0,0" />
    <Setter Property="HorizontalGridLinesBrush" Value="#E4EAF0" />
    <Setter Property="VerticalGridLinesBrush" Value="#EDF1F5" />
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="#EEF3F8" />
    <Setter Property="BorderBrush" Value="#D0D8E1" />
    <Setter Property="BorderThickness" Value="0,0,1,1" />
    <Setter Property="Foreground" Value="#607081" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="8,6" />
  </Style>

  <Style TargetType="DataGridCell">
    <Setter Property="BorderBrush" Value="#E1E7EE" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="8,6" />
  </Style>

  <Style x:Key="SelectableItemStyle" TargetType="ListBoxItem">
    <Setter Property="Padding" Value="10" />
    <Setter Property="Margin" Value="0,0,0,6" />
    <Setter Property="Background" Value="#FBFCFD" />
    <Setter Property="BorderBrush" Value="#D3DAE3" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border
              x:Name="Chrome"
              Padding="{TemplateBinding Padding}"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6">
            <ContentPresenter />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SelectionBrush}" />
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SelectionEdgeBrush}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="#8EABC9" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SummaryCardStyle" TargetType="Border">
    <Setter Property="Padding" Value="12" />
    <Setter Property="Margin" Value="0,0,8,8" />
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#D1D9E2" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style x:Key="ActionButtonStyle" TargetType="Button">
    <Setter Property="Padding" Value="12,7" />
    <Setter Property="Margin" Value="0,0,6,6" />
    <Setter Property="Background" Value="#F7FAFD" />
    <Setter Property="BorderBrush" Value="#AEB9C5" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinWidth" Value="92" />
    <Setter Property="Foreground" Value="#15202B" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border
              x:Name="Chrome"
              Padding="{TemplateBinding Padding}"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="5">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#EDF4FD" />
              <Setter TargetName="Chrome" Property="BorderBrush" Value="#89A8CC" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#DCE8FA" />
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Chrome" Property="Background" Value="#EFF2F5" />
              <Setter TargetName="Chrome" Property="BorderBrush" Value="#CDD4DB" />
              <Setter Property="Foreground" Value="#8A97A5" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="GhostActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#CCD5DE" />
  </Style>

  <Style x:Key="ContextBadgeStyle" TargetType="Border">
    <Setter Property="Margin" Value="0,0,6,6" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Background" Value="#F7FAFD" />
    <Setter Property="BorderBrush" Value="#C6D0DB" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style x:Key="StatusStripCellStyle" TargetType="Border">
    <Setter Property="BorderBrush" Value="#C4CED8" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="Padding" Value="10,3" />
  </Style>

  <Style x:Key="RailCardStyle" TargetType="Border">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#D1D9E2" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="Margin" Value="0,0,0,12" />
  </Style>

  <Style x:Key="LibraryBadgeStyle" TargetType="Border">
    <Setter Property="Margin" Value="0,0,6,6" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="Background" Value="#EEF3F8" />
    <Setter Property="BorderBrush" Value="#C7D1DB" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style x:Key="LibraryPanelCardStyle" TargetType="Border">
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#CFD8E1" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <DataTemplate DataType="{x:Type local:TemplateLibraryPanelModel}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <DockPanel>
          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Template Library Board" />
          <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding HeaderDetail}" />
        </DockPanel>
        <TextBlock Margin="0,3,0,10" FontSize="11" Foreground="#235FA9" Text="{Binding StatusSummary}" />

        <ItemsControl ItemsSource="{Binding SummaryCards}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource LibraryPanelCardStyle}">
                <StackPanel>
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Title}" />
                  <DockPanel Margin="0,4,0,3">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Value}" />
                  </DockPanel>
                  <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Detail}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Style="{StaticResource LibraryPanelCardStyle}">
          <StackPanel>
            <DockPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Entries" />
              <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding EntrySummary}" />
            </DockPanel>
            <ListBox
                Margin="0,8,0,0"
                ItemsSource="{Binding Entries}"
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                ItemContainerStyle="{StaticResource SelectableItemStyle}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel>
                    <DockPanel>
                      <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                      <TextBlock DockPanel.Dock="Right" Foreground="#235FA9" FontWeight="SemiBold" Text="{Binding State}" />
                    </DockPanel>
                    <WrapPanel Margin="0,4,0,2">
                      <Border Style="{StaticResource LibraryBadgeStyle}">
                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Source}" />
                      </Border>
                      <Border Style="{StaticResource LibraryBadgeStyle}">
                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Authority}" />
                      </Border>
                    </WrapPanel>
                    <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Dispatch}" />
                    <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" Text="{Binding Note}" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource LibraryPanelCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Selected Template" />
            <TextBlock Margin="0,4,0,0" FontWeight="SemiBold" Text="{Binding SelectionHeading}" />
            <TextBlock Margin="0,2,0,8" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding SelectionSummary}" />
            <ItemsControl ItemsSource="{Binding DetailRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="88" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap" Text="{Binding Value}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource LibraryPanelCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Operator Guidance" />
            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding GuidanceSections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8" Padding="8" Background="#FFFFFF" BorderBrush="#D0D8E1" BorderThickness="1">
                    <StackPanel>
                      <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                      <TextBlock Margin="0,2,0,6" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Summary}" />
                      <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid Margin="0,0,0,5">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                              <TextBlock Grid.Column="1" TextWrapping="Wrap" Text="{Binding Value}" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource LibraryPanelCardStyle}" Margin="0">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Current Alerts" />
            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding AlertRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,6" Padding="8" Background="#FFFFFF" BorderBrush="#D0D8E1" BorderThickness="1">
                    <StackPanel>
                      <DockPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Level}" />
                        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding Source}" />
                      </DockPanel>
                      <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" Text="{Binding Message}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DataTemplate>
</ResourceDictionary>
