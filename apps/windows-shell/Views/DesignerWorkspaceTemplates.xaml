<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:local="clr-namespace:JanLabel.WindowsShell"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    xmlns:propertyTools="clr-namespace:PropertyTools.Wpf;assembly=PropertyTools.Wpf">
  <DataTemplate DataType="{x:Type local:DesignerWorkspaceModel}">
    <avalonDock:DockingManager>
      <avalonDock:LayoutRoot>
        <avalonDock:LayoutPanel Orientation="Vertical">
          <avalonDock:LayoutPanel Orientation="Horizontal">
            <avalonDock:LayoutAnchorablePane DockWidth="300">
              <avalonDock:LayoutAnchorable Title="Toolbox" CanClose="False" CanHide="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Margin="10">
                    <DockPanel>
                      <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Toolbox" />
                      <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="Objects / guides" />
                    </DockPanel>
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ToolboxGroups}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,8" Padding="8" Background="#FCFDFE" BorderBrush="#D0D8E1" BorderThickness="1">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                              <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                      <TextBlock Text="{Binding Label}" />
                                      <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding Badge}" />
                                    </DockPanel>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ScrollViewer>
              </avalonDock:LayoutAnchorable>
              <avalonDock:LayoutAnchorable Title="Template Library" CanClose="False" CanHide="False">
                <Grid Margin="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Template Library" />
                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding CatalogSummary}" />
                  </DockPanel>
                  <ListView Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding TemplateRows}">
                    <ListView.View>
                      <GridView>
                        <GridViewColumn Width="114" DisplayMemberBinding="{Binding Name}" Header="Template" />
                        <GridViewColumn Width="68" DisplayMemberBinding="{Binding Source}" Header="Source" />
                        <GridViewColumn Width="68" DisplayMemberBinding="{Binding State}" Header="State" />
                        <GridViewColumn Width="190" DisplayMemberBinding="{Binding Note}" Header="Use" />
                      </GridView>
                    </ListView.View>
                  </ListView>
                </Grid>
              </avalonDock:LayoutAnchorable>
              <avalonDock:LayoutAnchorable Title="Object Browser" CanClose="False" CanHide="False">
                <Grid Margin="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Object Browser" />
                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="9 design objects" />
                  </DockPanel>
                  <TreeView Grid.Row="1" Margin="0,8,0,0" BorderBrush="#D0D8E1" BorderThickness="1" Background="#FFFFFF" ItemsSource="{Binding ObjectNodes}">
                    <TreeView.ItemTemplate>
                      <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <DockPanel>
                          <TextBlock Text="{Binding Label}" />
                          <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding Meta}" />
                        </DockPanel>
                      </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                  </TreeView>
                </Grid>
              </avalonDock:LayoutAnchorable>
              <avalonDock:LayoutAnchorable Title="Data Sources" CanClose="False" CanHide="False">
                <Grid Margin="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Data Sources" />
                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="6 mapped fields" />
                  </DockPanel>
                  <ListView Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding DataSources}">
                    <ListView.View>
                      <GridView>
                        <GridViewColumn Width="120" DisplayMemberBinding="{Binding Name}" Header="Field" />
                        <GridViewColumn Width="70" DisplayMemberBinding="{Binding Type}" Header="Type" />
                        <GridViewColumn Width="110" DisplayMemberBinding="{Binding Sample}" Header="Sample" />
                      </GridView>
                    </ListView.View>
                  </ListView>
                </Grid>
              </avalonDock:LayoutAnchorable>
            </avalonDock:LayoutAnchorablePane>

            <avalonDock:LayoutDocumentPaneGroup>
              <avalonDock:LayoutDocumentPane>
                <avalonDock:LayoutDocument Title="{Binding PrimaryDocumentTitle}" CanClose="False">
                  <Grid Margin="10">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                      <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Format Surface" />
                        <TextBlock Margin="0,2,0,0" FontWeight="SemiBold" Text="{Binding CanvasMeta}" />
                      </StackPanel>
                      <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="{Binding CanvasHint}" />
                    </DockPanel>
                    <Border Grid.Row="1" Margin="0,10,0,10" Padding="8" Background="#F5F8FB" BorderBrush="#C9D3DC" BorderThickness="1">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Margin="0,0,6,0" Padding="12,6" Content="Pointer" />
                        <Button Grid.Column="1" Margin="0,0,6,0" Padding="12,6" Content="Text" />
                        <Button Grid.Column="2" Margin="0,0,6,0" Padding="12,6" Content="Barcode" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="Dockable designer surface with package-backed tool windows." />
                      </Grid>
                    </Border>
                    <Border Grid.Row="2" Background="#E7ECF2" BorderBrush="#BCC7D2" BorderThickness="1">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="28" />
                          <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="28" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="1" Background="#EFF2F6" BorderBrush="#CBD4DD" BorderThickness="0,0,0,1">
                          <ItemsControl ItemsSource="{Binding TopRulerMarks}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="9" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border BorderBrush="#D0D8E1" BorderThickness="0,0,1,0">
                                  <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource MutedBrush}" Text="{Binding}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Background="#EFF2F6" BorderBrush="#CBD4DD" BorderThickness="0,0,1,0">
                          <ItemsControl ItemsSource="{Binding SideRulerMarks}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Height="44" BorderBrush="#D0D8E1" BorderThickness="0,0,0,1">
                                  <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource MutedBrush}" Text="{Binding}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Margin="20" Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" HorizontalAlignment="Center" VerticalAlignment="Top" Background="#FFFFFF" BorderBrush="#8D98A5" BorderThickness="1.2">
                          <Canvas Background="#FFFFFF" Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                            <ListBox
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding CanvasElements}"
                                SelectedItem="{Binding SelectedCanvasElement, Mode=TwoWay}">
                              <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <Canvas />
                                </ItemsPanelTemplate>
                              </ListBox.ItemsPanel>
                              <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                  <Setter Property="Background" Value="Transparent" />
                                  <Setter Property="BorderThickness" Value="0" />
                                  <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                  <Setter Property="Template">
                                    <Setter.Value>
                                      <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                      </ControlTemplate>
                                    </Setter.Value>
                                  </Setter>
                                  <Setter Property="Canvas.Left" Value="{Binding X}" />
                                  <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                              </ListBox.ItemContainerStyle>
                              <ListBox.ItemTemplate>
                                <DataTemplate>
                                  <Border Width="{Binding Width}" Height="{Binding Height}" Padding="4" Background="#F9FCFF" BorderBrush="#2B72C8" BorderThickness="1">
                                    <Border.Style>
                                      <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F9FCFF" />
                                        <Setter Property="BorderBrush" Value="#2B72C8" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                            <Setter Property="Background" Value="#FFF6D8" />
                                            <Setter Property="BorderBrush" Value="#CF8D20" />
                                            <Setter Property="BorderThickness" Value="1.8" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </Border.Style>
                                    <StackPanel>
                                      <TextBlock FontSize="10" Foreground="{StaticResource MutedBrush}" Text="{Binding Caption}" />
                                      <TextBlock FontSize="{Binding FontSize}" FontWeight="SemiBold" Text="{Binding Value}" />
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                          </Canvas>
                        </Border>
                      </Grid>
                    </Border>
                  </Grid>
                </avalonDock:LayoutDocument>
                <avalonDock:LayoutDocument Title="{Binding SecondaryDocumentTitle}" CanClose="False">
                  <Grid Margin="10">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                      <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Proof Preview" />
                        <TextBlock Margin="0,2,0,0" FontWeight="SemiBold" Text="Dispatch-safe summary before proof." />
                      </StackPanel>
                      <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="{Binding StatusSummary}" />
                    </DockPanel>
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <Border Margin="0,0,8,0" Padding="10" Background="#FFFFFF" BorderBrush="#C9D3DC" BorderThickness="1">
                        <StackPanel>
                          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Selected Record" />
                          <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding RecordRows}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                                  <TextBlock Grid.Column="1" FontFamily="Consolas" Text="{Binding Value}" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="1" Padding="10" Background="#FFFFFF" BorderBrush="#C9D3DC" BorderThickness="1">
                        <StackPanel>
                          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Release-Safe Rules" />
                          <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding PropertySections}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="8" Background="#FCFDFE" BorderBrush="#D0D8E1" BorderThickness="1">
                                  <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                    <TextBlock Margin="0,2,0,6" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Summary}" />
                                    <ItemsControl ItemsSource="{Binding Rows}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                          <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                              <ColumnDefinition Width="120" />
                                              <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                                            <TextBlock Grid.Column="1" TextWrapping="Wrap" Text="{Binding Value}" />
                                          </Grid>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </Grid>
                </avalonDock:LayoutDocument>
              </avalonDock:LayoutDocumentPane>
            </avalonDock:LayoutDocumentPaneGroup>

            <avalonDock:LayoutAnchorablePane DockWidth="360">
              <avalonDock:LayoutAnchorable Title="Document Setup" CanClose="False" CanHide="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Margin="10">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Document Setup" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SetupRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="112" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                            <TextBlock Grid.Column="1" FontFamily="Consolas" Text="{Binding Value}" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ScrollViewer>
              </avalonDock:LayoutAnchorable>
              <avalonDock:LayoutAnchorable Title="Selection Metrics" CanClose="False" CanHide="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Margin="10">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Selection Metrics" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SelectionRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="112" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                            <TextBlock Grid.Column="1" FontFamily="Consolas" Text="{Binding Value}" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ScrollViewer>
              </avalonDock:LayoutAnchorable>
              <avalonDock:LayoutAnchorable Title="Property Inspector" CanClose="False" CanHide="False">
                <Grid Margin="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Property Inspector" />
                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="PropertyTools.Wpf" />
                  </DockPanel>
                  <propertyTools:PropertyGrid Grid.Row="1" Margin="0,8,0,0" SelectedObject="{Binding SelectedElementProperties}" />
                </Grid>
              </avalonDock:LayoutAnchorable>
            </avalonDock:LayoutAnchorablePane>
          </avalonDock:LayoutPanel>

          <avalonDock:LayoutAnchorablePane DockHeight="245">
            <avalonDock:LayoutAnchorable Title="Messages" CanClose="False" CanHide="False">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Messages" />
                  <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding MessageSummary}" />
                </DockPanel>
                <ListView Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding MessageRows}">
                  <ListView.View>
                    <GridView>
                      <GridViewColumn Width="70" DisplayMemberBinding="{Binding Level}" Header="Level" />
                      <GridViewColumn Width="90" DisplayMemberBinding="{Binding Source}" Header="Source" />
                      <GridViewColumn Width="620" DisplayMemberBinding="{Binding Message}" Header="Message" />
                    </GridView>
                  </ListView.View>
                </ListView>
              </Grid>
            </avalonDock:LayoutAnchorable>
            <avalonDock:LayoutAnchorable Title="Selected Record" CanClose="False" CanHide="False">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Selected Record" />
                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding RecordSummary}" />
                  </DockPanel>
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding RecordRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,0,0,6">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                          <TextBlock Grid.Column="1" FontFamily="Consolas" Text="{Binding Value}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </avalonDock:LayoutAnchorable>
            <avalonDock:LayoutAnchorable Title="Integration Status" CanClose="False" CanHide="False">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Integration Status" />
                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding StatusSummary}" />
                  </DockPanel>
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding StatusItems}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="8" Background="#FCFDFE" BorderBrush="#CFD8E1" BorderThickness="1">
                          <DockPanel>
                            <StackPanel>
                              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Label}" />
                              <TextBlock FontWeight="SemiBold" Text="{Binding Value}" />
                              <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Detail}" />
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Right" Foreground="{Binding Accent}" FontWeight="SemiBold" Text="{Binding Tone}" />
                          </DockPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </avalonDock:LayoutAnchorable>
          </avalonDock:LayoutAnchorablePane>
        </avalonDock:LayoutPanel>
      </avalonDock:LayoutRoot>
    </avalonDock:DockingManager>
  </DataTemplate>
</ResourceDictionary>
