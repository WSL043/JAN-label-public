<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:JanLabel.WindowsShell">
  <DataTemplate DataType="{x:Type local:HomeWorkspaceModel}">
    <DockPanel LastChildFill="True">
      <Border DockPanel.Dock="Bottom" Background="#E6EBF1" BorderBrush="#BCC7D2" BorderThickness="1,1,0,0">
        <Grid Margin="8,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="1*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Style="{StaticResource PaneBorderStyle}" Margin="0,0,8,0">
            <StackPanel>
              <DockPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Operational Status" />
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="live baseline" />
              </DockPanel>
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding StatusItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,6" Padding="8" Background="#FCFDFE" BorderBrush="#CFD8E1" BorderThickness="1">
                      <DockPanel>
                        <StackPanel>
                          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Label}" />
                          <TextBlock FontWeight="SemiBold" Text="{Binding Value}" />
                          <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Detail}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" Foreground="{Binding Accent}" FontWeight="SemiBold" Text="{Binding Tone}" />
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource PaneBorderStyle}" Margin="0">
            <StackPanel>
              <DockPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent Activity" />
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="latest 6 events" />
              </DockPanel>
              <ListView Margin="0,8,0,0" Height="156" ItemsSource="{Binding ActivityRows}">
                <ListView.View>
                  <GridView>
                    <GridViewColumn Width="76" DisplayMemberBinding="{Binding Time}" Header="Time" />
                    <GridViewColumn Width="90" DisplayMemberBinding="{Binding Lane}" Header="Lane" />
                    <GridViewColumn Width="300" DisplayMemberBinding="{Binding Summary}" Header="Summary" />
                    <GridViewColumn Width="90" DisplayMemberBinding="{Binding Status}" Header="State" />
                  </GridView>
                </ListView.View>
              </ListView>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="300" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,8,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Style="{StaticResource PaneBorderStyle}">
            <StackPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Current Session" />
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SessionRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                      <TextBlock Grid.Column="1" FontFamily="Consolas" Text="{Binding Value}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
          <Border Grid.Row="1" Style="{StaticResource PaneBorderStyle}" Margin="0">
            <StackPanel>
              <DockPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Template Library Snapshot" />
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="packaged + local" />
              </DockPanel>
              <ListView Margin="0,8,0,0" ItemsSource="{Binding TemplateRows}">
                <ListView.View>
                  <GridView>
                    <GridViewColumn Width="132" DisplayMemberBinding="{Binding Name}" Header="Template" />
                    <GridViewColumn Width="78" DisplayMemberBinding="{Binding Source}" Header="Source" />
                    <GridViewColumn Width="78" DisplayMemberBinding="{Binding State}" Header="State" />
                    <GridViewColumn Width="190" DisplayMemberBinding="{Binding Note}" Header="Operator note" />
                  </GridView>
                </ListView.View>
              </ListView>
            </StackPanel>
          </Border>
        </Grid>

        <Grid Grid.Column="1" Margin="0,0,8,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Style="{StaticResource PaneBorderStyle}">
            <StackPanel>
              <DockPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Workstation Readiness" />
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding HeaderDetail}" />
              </DockPanel>
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource SummaryCardStyle}" Width="188">
                      <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Title}" />
                        <TextBlock Margin="0,6,0,4" FontSize="24" FontWeight="SemiBold" Text="{Binding Value}" />
                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Detail}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
          <Border Grid.Row="1" Style="{StaticResource PaneBorderStyle}" Margin="0">
            <StackPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Migration Scope" />
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ControlSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,8" Padding="8" Background="#FCFDFE" BorderBrush="#D0D8E1" BorderThickness="1">
                      <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                        <TextBlock Margin="0,2,0,6" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Summary}" />
                        <ItemsControl ItemsSource="{Binding Rows}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="130" />
                                  <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                                <TextBlock Grid.Column="1" TextWrapping="Wrap" Text="{Binding Value}" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource PaneBorderStyle}" Margin="0">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Next Operator Steps" />
            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding NextSteps}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8" Padding="8" Background="#FCFDFE" BorderBrush="#D0D8E1" BorderThickness="1">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Subtext}" />
                        <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" Text="{Binding Note}" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Foreground="#235FA9" FontWeight="SemiBold" Text="{Binding Badge}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>
    </DockPanel>
  </DataTemplate>
</ResourceDictionary>
