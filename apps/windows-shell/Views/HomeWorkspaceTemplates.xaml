<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:JanLabel.WindowsShell">
  <DataTemplate DataType="{x:Type local:HomeWorkspaceModel}">
    <DockPanel LastChildFill="True">
      <Border DockPanel.Dock="Bottom" Background="#E6EBF1" BorderBrush="#BCC7D2" BorderThickness="1,1,0,0">
        <Grid Margin="8,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="1*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Style="{StaticResource PaneBorderStyle}" Margin="0,0,8,0">
            <StackPanel>
              <DockPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Operational Status" />
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding StatusSummary}" />
              </DockPanel>
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding StatusItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,6" Padding="8" Background="#FCFDFE" BorderBrush="#CFD8E1" BorderThickness="1">
                      <DockPanel>
                        <StackPanel>
                          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Label}" />
                          <TextBlock FontWeight="SemiBold" Text="{Binding Value}" />
                          <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Detail}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" Foreground="{Binding Accent}" FontWeight="SemiBold" Text="{Binding Tone}" />
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource PaneBorderStyle}" Margin="0">
            <StackPanel>
              <DockPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent Activity" />
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding ActivitySummary}" />
              </DockPanel>
              <DataGrid Style="{StaticResource OperatorDataGridStyle}" ItemsSource="{Binding ActivityRows}">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="76" Binding="{Binding Time}" Header="Time" />
                  <DataGridTextColumn Width="90" Binding="{Binding Lane}" Header="Lane" />
                  <DataGridTextColumn Width="*" Binding="{Binding Summary}" Header="Summary" />
                  <DataGridTextColumn Width="90" Binding="{Binding Status}" Header="State" />
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="320" MinWidth="260" />
          <ColumnDefinition Width="6" />
          <ColumnDefinition Width="*" MinWidth="420" />
          <ColumnDefinition Width="6" />
          <ColumnDefinition Width="400" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource PaneBorderStyle}" Margin="0,0,8,0">
          <TabControl Style="{StaticResource WorksurfaceTabControlStyle}">
            <TabItem Header="Current Session">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Current Session" />
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SessionRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,0,0,6">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                          <TextBlock Grid.Column="1" FontFamily="Consolas" Text="{Binding Value}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
            <TabItem Header="Template Library">
              <Border Margin="10" Background="Transparent">
                <ContentControl Content="{Binding TemplateLibrary}" />
              </Border>
            </TabItem>
          </TabControl>
        </Border>

        <GridSplitter Grid.Column="1" Style="{StaticResource PaneGridSplitterStyle}" ResizeDirection="Columns" />

        <Border Grid.Column="2" Style="{StaticResource PaneBorderStyle}" Margin="0,0,8,0">
          <TabControl Style="{StaticResource WorksurfaceTabControlStyle}">
            <TabItem Header="Readiness">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Workstation Readiness" />
                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding HeaderDetail}" />
                  </DockPanel>
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SummaryCards}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Style="{StaticResource SummaryCardStyle}" Width="188">
                          <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Title}" />
                            <TextBlock Margin="0,6,0,4" FontSize="24" FontWeight="SemiBold" Text="{Binding Value}" />
                            <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Detail}" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
            <TabItem Header="Migration Scope">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Migration Scope" />
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ControlSections}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="8" Background="#FCFDFE" BorderBrush="#D0D8E1" BorderThickness="1">
                          <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                            <TextBlock Margin="0,2,0,6" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Summary}" />
                            <ItemsControl ItemsSource="{Binding Rows}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                      <ColumnDefinition Width="130" />
                                      <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1" TextWrapping="Wrap" Text="{Binding Value}" />
                                  </Grid>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Border>

        <GridSplitter Grid.Column="3" Style="{StaticResource PaneGridSplitterStyle}" ResizeDirection="Columns" />

        <Border Grid.Column="4" Style="{StaticResource PaneBorderStyle}" Margin="0">
          <TabControl Style="{StaticResource WorksurfaceTabControlStyle}">
            <TabItem Header="Next Steps">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Next Operator Steps" />
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding NextSteps}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="8" Background="#FCFDFE" BorderBrush="#D0D8E1" BorderThickness="1">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                              <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Subtext}" />
                              <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" Text="{Binding Note}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Foreground="#235FA9" FontWeight="SemiBold" Text="{Binding Badge}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
            <TabItem Header="Activity Feed">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent Activity" />
                  <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding ActivitySummary}" />
                </DockPanel>
                <DataGrid Grid.Row="1" Style="{StaticResource OperatorDataGridStyle}" ItemsSource="{Binding ActivityRows}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Width="76" Binding="{Binding Time}" Header="Time" />
                    <DataGridTextColumn Width="90" Binding="{Binding Lane}" Header="Lane" />
                    <DataGridTextColumn Width="*" Binding="{Binding Summary}" Header="Summary" />
                    <DataGridTextColumn Width="90" Binding="{Binding Status}" Header="State" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
          </TabControl>
        </Border>
      </Grid>
    </DockPanel>
  </DataTemplate>
</ResourceDictionary>
