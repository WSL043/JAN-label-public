<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:JanLabel.WindowsShell">
  <DataTemplate DataType="{x:Type local:BatchJobsWorkspaceModel}">
    <DockPanel LastChildFill="True">
      <Border DockPanel.Dock="Bottom" Background="#E6EBF1" BorderBrush="#BCC7D2" BorderThickness="1,1,0,0">
        <Grid Margin="8,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="1*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Style="{StaticResource PaneBorderStyle}" Margin="0,0,8,0">
            <StackPanel>
              <DockPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Validation Messages" />
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding MessageSummary}" />
              </DockPanel>
              <DataGrid Style="{StaticResource OperatorDataGridStyle}" ItemsSource="{Binding MessageRows}">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="70" Binding="{Binding Level}" Header="Level" />
                  <DataGridTextColumn Width="90" Binding="{Binding Source}" Header="Source" />
                  <DataGridTextColumn Width="*" Binding="{Binding Message}" Header="Message" />
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource PaneBorderStyle}" Margin="0">
            <StackPanel>
              <DockPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Queue Health" />
                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding FooterDetail}" />
              </DockPanel>
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding StatusItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,6" Padding="8" Background="#FCFDFE" BorderBrush="#CFD8E1" BorderThickness="1">
                      <DockPanel>
                        <StackPanel>
                          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Label}" />
                          <TextBlock FontWeight="SemiBold" Text="{Binding Value}" />
                          <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Detail}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" Foreground="{Binding Accent}" FontWeight="SemiBold" Text="{Binding Tone}" />
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="320" MinWidth="260" />
          <ColumnDefinition Width="6" />
          <ColumnDefinition Width="*" MinWidth="420" />
          <ColumnDefinition Width="6" />
          <ColumnDefinition Width="400" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource PaneBorderStyle}" Margin="0,0,8,0">
          <TabControl Style="{StaticResource WorksurfaceTabControlStyle}">
            <TabItem Header="Import Sessions">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Import Sessions" />
                  <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding ImportSummary}" />
                </DockPanel>
                <DataGrid
                    Grid.Row="1"
                    Style="{StaticResource OperatorDataGridStyle}"
                    ItemsSource="{Binding ImportSessions}"
                    SelectedItem="{Binding SelectedImportSession, Mode=TwoWay}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Width="150" Binding="{Binding Label}" Header="Session" />
                    <DataGridTextColumn Width="90" Binding="{Binding Badge}" Header="State" />
                    <DataGridTextColumn Width="150" Binding="{Binding Subtext}" Header="Source" />
                    <DataGridTextColumn Width="*" Binding="{Binding Note}" Header="Operator note" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
            <TabItem Header="Mapped Columns">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Mapped Columns" />
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ColumnRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,0,0,6">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                          <TextBlock Grid.Column="1" TextWrapping="Wrap" Text="{Binding Value}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Border>

        <GridSplitter Grid.Column="1" Style="{StaticResource PaneGridSplitterStyle}" ResizeDirection="Columns" />

        <Border Grid.Column="2" Style="{StaticResource PaneBorderStyle}" Margin="0,0,8,0">
          <TabControl Style="{StaticResource WorksurfaceTabControlStyle}">
            <TabItem Header="Batch Queue">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Batch Queue" />
                  <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding QueueSummary}" />
                </DockPanel>
                <DataGrid
                    Grid.Row="1"
                    Style="{StaticResource OperatorDataGridStyle}"
                    ItemsSource="{Binding BatchRows}"
                    SelectedItem="{Binding SelectedBatch, Mode=TwoWay}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Width="110" Binding="{Binding BatchId}" Header="Batch" />
                    <DataGridTextColumn Width="130" Binding="{Binding Template}" Header="Template" />
                    <DataGridTextColumn Width="80" Binding="{Binding Records}" Header="Records" />
                    <DataGridTextColumn Width="90" Binding="{Binding Status}" Header="State" />
                    <DataGridTextColumn Width="120" Binding="{Binding SubmitRoute}" Header="Route" />
                    <DataGridTextColumn Width="*" Binding="{Binding Note}" Header="Operator note" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
            <TabItem Header="Snapshot Activity">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Snapshot Activity" />
                  <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Text="{Binding ActivitySummary}" />
                </DockPanel>
                <DataGrid Grid.Row="1" Style="{StaticResource OperatorDataGridStyle}" ItemsSource="{Binding ActivityRows}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Width="80" Binding="{Binding Time}" Header="Time" />
                    <DataGridTextColumn Width="90" Binding="{Binding Lane}" Header="Lane" />
                    <DataGridTextColumn Width="*" Binding="{Binding Summary}" Header="Summary" />
                    <DataGridTextColumn Width="90" Binding="{Binding Status}" Header="State" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
          </TabControl>
        </Border>

        <GridSplitter Grid.Column="3" Style="{StaticResource PaneGridSplitterStyle}" ResizeDirection="Columns" />

        <Border Grid.Column="4" Style="{StaticResource PaneBorderStyle}" Margin="0">
          <TabControl Style="{StaticResource WorksurfaceTabControlStyle}">
            <TabItem Header="Current Focus">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Current Queue Focus" />
                  <TextBlock Margin="0,4,0,0" FontWeight="SemiBold" Text="{Binding SelectionHeading}" />
                  <TextBlock Margin="0,2,0,8" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding SelectionSummary}" />
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SessionDetailRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,0,0,6">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                          <TextBlock Grid.Column="1" TextWrapping="Wrap" Text="{Binding Value}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
            <TabItem Header="Guardrails">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Batch Guardrails" />
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ControlSections}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="8" Background="#FCFDFE" BorderBrush="#D0D8E1" BorderThickness="1">
                          <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                            <TextBlock Margin="0,2,0,6" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Summary}" />
                            <ItemsControl ItemsSource="{Binding Rows}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                      <ColumnDefinition Width="118" />
                                      <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1" TextWrapping="Wrap" Text="{Binding Value}" />
                                  </Grid>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Border>
      </Grid>
    </DockPanel>
  </DataTemplate>
</ResourceDictionary>
