<adonisControls:AdonisWindow
    x:Class="JanLabel.WindowsShell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{Binding WindowTitle}"
    Width="1780"
    Height="1060"
    MinWidth="1480"
    MinHeight="900"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource AppBackgroundBrush}"
    TitleBarBackground="{StaticResource TitleBarBackgroundBrush}"
    TitleBarForeground="{StaticResource TitleBarForegroundBrush}"
    WindowButtonHighlightBrush="{StaticResource AccentSoftBrush}"
    FontFamily="Segoe UI">
  <adonisControls:AdonisWindow.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Views/CommonTemplates.xaml" />
        <ResourceDictionary Source="Views/HomeWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/DesignerWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/PrintConsoleWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/BatchJobsWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/HistoryWorkspaceTemplates.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </adonisControls:AdonisWindow.Resources>

  <adonisControls:AdonisWindow.TitleBarContent>
    <Grid Width="700">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock
          VerticalAlignment="Center"
          Foreground="{StaticResource MutedBrush}"
          Text="{Binding LastActionStatus}"
          TextTrimming="CharacterEllipsis" />
      <ItemsControl Grid.Column="1" Margin="16,0,0,0" ItemsSource="{Binding CurrentContextBadges}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource ContextBadgeStyle}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,6,0" Foreground="{StaticResource MutedBrush}" Text="{Binding Label}" />
                <TextBlock FontWeight="SemiBold" Foreground="{Binding Accent}" Text="{Binding Value}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
  </adonisControls:AdonisWindow.TitleBarContent>

  <Grid Background="{StaticResource AppBackgroundBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="Refresh Workspace" Tag="{Binding QuickAccessRefreshAction}" Click="ShellActionButton_Click" />
        <Separator />
        <MenuItem Header="E_xit" Click="ExitMenuItem_Click" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Home" Tag="Home" Click="NavigateMenuItem_Click" />
        <MenuItem Header="Designer" Tag="Designer" Click="NavigateMenuItem_Click" />
        <MenuItem Header="Print Console" Tag="Print Console" Click="NavigateMenuItem_Click" />
        <MenuItem Header="Batch Jobs" Tag="Batch Jobs" Click="NavigateMenuItem_Click" />
        <MenuItem Header="History" Tag="History" Click="NavigateMenuItem_Click" />
      </MenuItem>
      <MenuItem Header="_Actions">
        <MenuItem
            Header="{Binding QuickAccessRefreshAction.Label}"
            Tag="{Binding QuickAccessRefreshAction}"
            IsEnabled="{Binding QuickAccessRefreshAction.IsEnabled}"
            Click="ShellActionButton_Click" />
        <MenuItem
            Header="{Binding QuickAccessPreviewAction.Label}"
            Tag="{Binding QuickAccessPreviewAction}"
            IsEnabled="{Binding QuickAccessPreviewAction.IsEnabled}"
            Click="ShellActionButton_Click" />
        <MenuItem
            Header="{Binding QuickAccessApproveAction.Label}"
            Tag="{Binding QuickAccessApproveAction}"
            IsEnabled="{Binding QuickAccessApproveAction.IsEnabled}"
            Click="ShellActionButton_Click" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="About This Preview" Click="ShowAboutMenuItem_Click" />
      </MenuItem>
    </Menu>

    <ToolBarTray Grid.Row="1" Background="Transparent" IsLocked="True">
      <ToolBar>
        <Button
            MinWidth="118"
            Content="{Binding QuickAccessRefreshAction.Label}"
            IsEnabled="{Binding QuickAccessRefreshAction.IsEnabled}"
            Tag="{Binding QuickAccessRefreshAction}"
            ToolTip="{Binding QuickAccessRefreshAction.Summary}"
            Click="ShellActionButton_Click" />
        <Button
            MinWidth="118"
            Content="{Binding QuickAccessPreviewAction.Label}"
            IsEnabled="{Binding QuickAccessPreviewAction.IsEnabled}"
            Tag="{Binding QuickAccessPreviewAction}"
            ToolTip="{Binding QuickAccessPreviewAction.Summary}"
            Click="ShellActionButton_Click" />
        <Button
            MinWidth="118"
            Content="{Binding QuickAccessApproveAction.Label}"
            IsEnabled="{Binding QuickAccessApproveAction.IsEnabled}"
            Tag="{Binding QuickAccessApproveAction}"
            ToolTip="{Binding QuickAccessApproveAction.Summary}"
            Click="ShellActionButton_Click" />
        <Separator />
        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding WorkspaceTagline}" />
      </ToolBar>
    </ToolBarTray>

    <Grid Grid.Row="2" Margin="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="270" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="320" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Application" Margin="0,0,0,12">
          <StackPanel Margin="12">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="JAN Label" />
            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}" Text="{Binding WorkspaceTagline}" TextWrapping="Wrap" />
          </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Workspaces">
          <DockPanel Margin="12" LastChildFill="True">
            <TextBlock
                DockPanel.Dock="Top"
                Margin="0,0,0,10"
                Foreground="{StaticResource MutedBrush}"
                Text="Operator lanes and live companion surfaces."
                TextWrapping="Wrap" />
            <ListBox
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding Modules}"
                SelectedItem="{Binding SelectedModule}"
                ItemContainerStyle="{StaticResource SelectableItemStyle}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                      <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Description}" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Text="{Binding Badge}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Current State" Margin="0,12,0,0">
          <StackPanel Margin="12">
            <TextBlock FontWeight="SemiBold" Text="{Binding LastActionStatus}" TextWrapping="Wrap" />
          </StackPanel>
        </GroupBox>
      </Grid>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" ShowsPreview="True" HorizontalAlignment="Stretch" />

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Current Workspace" Margin="0,0,0,12">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding WindowTitle}" />
              <TextBlock Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" Text="{Binding CurrentWorkspaceLead}" TextWrapping="Wrap" />
            </StackPanel>
            <ItemsControl Grid.Column="1" Margin="16,0,0,0" ItemsSource="{Binding CurrentContextBadges}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource ContextBadgeStyle}">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Margin="0,0,6,0" Foreground="{StaticResource MutedBrush}" Text="{Binding Label}" />
                      <TextBlock FontWeight="SemiBold" Foreground="{Binding Accent}" Text="{Binding Value}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Work Area">
          <ContentControl Content="{Binding CurrentWorkspace}" />
        </GroupBox>
      </Grid>

      <GridSplitter Grid.Column="3" ResizeDirection="Columns" ShowsPreview="True" HorizontalAlignment="Stretch" />

      <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <GroupBox Header="Actions" Margin="0,0,0,12">
            <StackPanel Margin="12">
              <ItemsControl ItemsSource="{Binding CurrentHeaderActions}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button
                        Margin="0,0,0,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Content="{Binding Label}"
                        IsEnabled="{Binding IsEnabled}"
                        Tag="{Binding}"
                        ToolTip="{Binding Summary}"
                        Click="ShellActionButton_Click" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </GroupBox>

          <GroupBox Header="Context" Margin="0,0,0,12">
            <StackPanel Margin="12">
              <ItemsControl ItemsSource="{Binding CurrentContextBadges}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource ContextBadgeStyle}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Label}" />
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Foreground="{Binding Accent}" Text="{Binding Value}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </GroupBox>

          <GroupBox Header="Session Details">
            <StackPanel Margin="12">
              <ItemsControl ItemsSource="{Binding CurrentStatusStripItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding Label}" />
                      <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding Value}" TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </GroupBox>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <StatusBar Grid.Row="3">
      <ItemsControl ItemsSource="{Binding CurrentStatusStripItems}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource StatusStripCellStyle}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,6,0" Foreground="{StaticResource MutedBrush}" Text="{Binding Label}" />
                <TextBlock FontWeight="SemiBold" Text="{Binding Value}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StatusBar>
  </Grid>
</adonisControls:AdonisWindow>
