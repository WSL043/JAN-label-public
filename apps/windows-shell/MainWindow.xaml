<Window
    x:Class="JanLabel.WindowsShell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    mc:Ignorable="d"
    Title="{Binding WindowTitle}"
    Width="1600"
    Height="960"
    MinWidth="1440"
    MinHeight="900"
    WindowStartupLocation="CenterScreen"
    Background="#EEF1F5"
    FontFamily="Segoe UI">
  <Window.Resources>
    <SolidColorBrush x:Key="ChromeBrush" Color="#E7EBF0" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FBFCFD" />
    <SolidColorBrush x:Key="PanelEdgeBrush" Color="#B8C3CF" />
    <Style x:Key="MenuButtonStyle" TargetType="Button">
      <Setter Property="Margin" Value="0,0,2,0" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="BorderBrush" Value="#C0C8D0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style x:Key="RibbonButtonStyle" TargetType="Button">
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#B6C0CB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#F9FAFB" />
      <Setter Property="MinWidth" Value="110" />
    </Style>
    <Style x:Key="PaneBorderStyle" TargetType="Border">
      <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="Padding" Value="10" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style x:Key="PaneHeaderStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#5A6774" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" BorderBrush="#BCC7D2" BorderThickness="0,0,0,1" Background="#F4F6F8">
      <Grid Margin="8,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="280" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock FontSize="15" FontWeight="SemiBold" Text="JAN Label Operator Console" />
          <TextBlock FontSize="11" Foreground="#667382" Text="Windows-native workstation shell" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
          <Button Style="{StaticResource MenuButtonStyle}" Content="File" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Edit" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="View" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Data" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Template" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Tools" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Window" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Help" />
        </StackPanel>

        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
          <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Document" />
          <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding ActiveDocumentName}" />
          <TextBlock FontSize="11" Foreground="#667382" Text="{Binding ActiveDocumentMeta}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" BorderBrush="#BCC7D2" BorderThickness="0,0,0,1" Background="{StaticResource ChromeBrush}">
      <Grid Margin="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#B8C3CF" BorderThickness="1" Background="#FCFDFE" Padding="10" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Workspace" />
            <TextBlock FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" Text="{Binding WorkspaceTitle}" />
            <TextBlock FontSize="12" Foreground="#5C6977" TextWrapping="Wrap" Text="{Binding WorkspaceSummary}" />
            <primitives:UniformGrid Columns="3" Margin="0,10,0,0">
              <Border Margin="0,0,6,0" Padding="8" BorderBrush="#D0D7DE" BorderThickness="1" Background="#F8FAFC">
                <StackPanel>
                  <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Bridge" />
                  <TextBlock FontWeight="SemiBold" Text="ready" />
                  <TextBlock FontSize="11" Foreground="#667382" Text="desktop-shell" />
                </StackPanel>
              </Border>
              <Border Margin="0,0,6,0" Padding="8" BorderBrush="#D0D7DE" BorderThickness="1" Background="#F8FAFC">
                <StackPanel>
                  <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Payload" />
                  <TextBlock FontWeight="SemiBold" Text="armed" />
                  <TextBlock FontSize="11" Foreground="#667382" Text="proof route" />
                </StackPanel>
              </Border>
              <Border Padding="8" BorderBrush="#D0D7DE" BorderThickness="1" Background="#F8FAFC">
                <StackPanel>
                  <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Queue" />
                  <TextBlock FontWeight="SemiBold" Text="42 rows" />
                  <TextBlock FontSize="11" Foreground="#667382" Text="31 ready / 1 failed" />
                </StackPanel>
              </Border>
            </primitives:UniformGrid>
          </StackPanel>
        </Border>

        <ItemsControl Grid.Column="1" ItemsSource="{Binding RibbonGroups}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Width="220" Margin="0,0,8,0" Padding="10" BorderBrush="#B8C3CF" BorderThickness="1" Background="#FCFDFE">
                <StackPanel>
                  <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="{Binding Title}" />
                  <ItemsControl ItemsSource="{Binding Commands}" Margin="0,8,0,0">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Style="{StaticResource RibbonButtonStyle}" Content="{Binding}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <Grid Grid.Row="2" Margin="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="340" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0" Margin="0,0,8,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PaneBorderStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Explorer" />
            <ListBox
                Margin="0,8,0,0"
                ItemsSource="{Binding Modules}"
                SelectedItem="{Binding SelectedModule}"
                BorderThickness="0"
                Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Padding="8" Margin="0,0,0,4" BorderBrush="#D1D8DF" BorderThickness="1" Background="#F7F9FB">
                    <StackPanel>
                      <DockPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                        <TextBlock DockPanel.Dock="Right" Foreground="#0F5CC0" FontWeight="SemiBold" Text="{Binding Badge}" />
                      </DockPanel>
                      <TextBlock FontSize="11" Foreground="#667382" TextWrapping="Wrap" Text="{Binding Description}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PaneBorderStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="{Binding ToolPaneTitle}" />
            <ItemsControl ItemsSource="{Binding ToolPaneItems}" Margin="0,8,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,4" Padding="8" BorderBrush="#D1D8DF" BorderThickness="1" Background="#F7F9FB">
                    <DockPanel>
                      <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                      <TextBlock DockPanel.Dock="Right" Foreground="#5E6B79" Text="{Binding Badge}" />
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PaneBorderStyle}" Margin="0">
          <StackPanel>
            <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Properties" />
            <ItemsControl ItemsSource="{Binding DocumentProperties}" Margin="0,8,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="100" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="#667382" Text="{Binding Name}" />
                    <TextBlock Grid.Column="1" FontFamily="Consolas" FontSize="12" Text="{Binding Value}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="#667382" TextWrapping="Wrap" Text="{Binding WorkspaceFocus}" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid Grid.Column="1" Margin="0,0,8,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PaneBorderStyle}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Workbench" />
              <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" Text="{Binding WorkspaceTitle}" />
              <TextBlock FontSize="12" Foreground="#5C6977" TextWrapping="Wrap" Text="{Binding WorkspaceSummary}" />
            </StackPanel>
            <Border Grid.Column="1" BorderBrush="#D1D8DF" BorderThickness="1" Background="#F7F9FB" Padding="8">
              <StackPanel>
                <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="Current Focus" />
                <TextBlock FontSize="12" TextWrapping="Wrap" Text="{Binding WorkspaceFocus}" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding WorkbenchPanels}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Width="360" Margin="0,0,8,8" Padding="10" BorderBrush="#B8C3CF" BorderThickness="1" Background="#FCFDFE">
                  <StackPanel>
                    <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="{Binding Title}" />
                    <TextBlock Margin="0,4,0,0" FontSize="14" FontWeight="SemiBold" Text="{Binding Summary}" />
                    <ItemsControl ItemsSource="{Binding Lines}" Margin="0,8,0,0">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,4" Padding="6" BorderBrush="#D7DEE5" BorderThickness="1" Background="#F7F9FB">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Text="{Binding}" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>

      <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding InspectorSections}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource PaneBorderStyle}">
                <StackPanel>
                  <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="{Binding Title}" />
                  <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Text="{Binding Summary}" />
                  <ItemsControl ItemsSource="{Binding Rows}" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,0,0,6">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Foreground="#667382" Text="{Binding Name}" />
                          <TextBlock Grid.Column="1" FontSize="12" TextWrapping="Wrap" Text="{Binding Value}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <Border Grid.Row="3" BorderBrush="#BCC7D2" BorderThickness="1,1,0,0" Background="#DFE5EC">
      <ItemsControl ItemsSource="{Binding StatusItems}" Margin="8,6">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <primitives:UniformGrid Columns="4" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,6,0" Padding="6" BorderBrush="#B8C3CF" BorderThickness="1" Background="#F9FAFB">
              <StackPanel>
                <TextBlock Style="{StaticResource PaneHeaderStyle}" Text="{Binding Label}" />
                <TextBlock FontWeight="SemiBold" Text="{Binding Value}" />
                <TextBlock FontSize="11" Foreground="#667382" Text="{Binding Detail}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>
  </Grid>
</Window>
