<Fluent:RibbonWindow
    x:Class="JanLabel.WindowsShell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:Fluent="urn:fluent-ribbon"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{Binding WindowTitle}"
    Width="1760"
    Height="1040"
    MinWidth="1520"
    MinHeight="920"
    WindowStartupLocation="CenterScreen"
    Background="#D9DEE5"
    BorderBrush="#AEB9C5"
    TitleBackground="#EAF0F6"
    TitleForeground="#17212B"
    FontFamily="Segoe UI">
  <Fluent:RibbonWindow.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Views/CommonTemplates.xaml" />
        <ResourceDictionary Source="Views/HomeWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/DesignerWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/PrintConsoleWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/BatchJobsWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/HistoryWorkspaceTemplates.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Fluent:RibbonWindow.Resources>

  <DockPanel LastChildFill="True">
    <Fluent:Ribbon DockPanel.Dock="Top" CanCustomizeQuickAccessToolBar="False">
      <Fluent:Ribbon.Menu>
        <Fluent:Backstage>
          <Fluent:BackstageTabControl>
            <Fluent:BackstageTabItem Header="File">
              <StackPanel Margin="24">
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="JAN Label Workstation" />
                <TextBlock Margin="0,8,0,14" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="{Binding WorkspaceTagline}" />
                <ItemsControl ItemsSource="{Binding CurrentHeaderActions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Style="{StaticResource ActionButtonStyle}" Margin="0,0,0,8" Content="{Binding}" Tag="{Binding}" Click="ShellActionButton_Click" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Fluent:BackstageTabItem>
            <Fluent:BackstageTabItem Header="Workspace">
              <StackPanel Margin="24">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Current Workspace" />
                <TextBlock Margin="0,8,0,12" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding CurrentWorkspaceLead}" />
                <ItemsControl ItemsSource="{Binding CurrentContextBadges}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Style="{StaticResource ContextBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Margin="0,0,6,0" Foreground="{StaticResource MutedBrush}" Text="{Binding Label}" />
                          <TextBlock FontWeight="SemiBold" Foreground="{Binding Accent}" Text="{Binding Value}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Fluent:BackstageTabItem>
          </Fluent:BackstageTabControl>
        </Fluent:Backstage>
      </Fluent:Ribbon.Menu>

      <Fluent:Ribbon.QuickAccessItems>
        <Fluent:Button Header="Refresh" Click="QuickAccessButton_Click" />
        <Fluent:Button Header="Preview" Click="QuickAccessButton_Click" />
        <Fluent:Button Header="Proof" Click="QuickAccessButton_Click" />
      </Fluent:Ribbon.QuickAccessItems>

      <Fluent:RibbonTabItem Header="Workspace">
        <ItemsControl ItemsSource="{Binding CurrentRibbonGroups}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Fluent:RibbonGroupBox Header="{Binding Title}" Margin="0,0,8,0">
                <ItemsControl ItemsSource="{Binding Commands}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Fluent:Button Header="{Binding}" Tag="{Binding}" SizeDefinition="Large" Margin="0,0,6,0" Click="RibbonActionButton_Click" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Fluent:RibbonGroupBox>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Fluent:RibbonTabItem>
    </Fluent:Ribbon>

    <Border DockPanel.Dock="Top" Background="{StaticResource RibbonBrush}" BorderBrush="#BCC7D2" BorderThickness="0,0,0,1">
      <Grid Margin="8,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ListBox
            Grid.Column="0"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Modules}"
            SelectedItem="{Binding SelectedModule}"
            ItemContainerStyle="{StaticResource SelectableItemStyle}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Width="214">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                  <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Description}" />
                </StackPanel>
                <TextBlock Grid.Column="1" Foreground="#235FA9" FontWeight="SemiBold" Text="{Binding Badge}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <ItemsControl Grid.Column="1" Margin="8,0,0,0" ItemsSource="{Binding CurrentHeaderActions}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding}" Tag="{Binding}" Click="ShellActionButton_Click" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top" Background="#F4F7FA" BorderBrush="#C6D0DB" BorderThickness="0,0,0,1">
      <Grid Margin="10,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding WindowTitle}" />
          <TextBlock Margin="0,3,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Text="{Binding CurrentWorkspaceLead}" />
          <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#235FA9" Text="{Binding LastActionStatus}" />
        </StackPanel>
        <ItemsControl Grid.Column="1" Margin="12,0,0,0" ItemsSource="{Binding CurrentContextBadges}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource ContextBadgeStyle}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Margin="0,0,6,0" Foreground="{StaticResource MutedBrush}" Text="{Binding Label}" />
                  <TextBlock FontWeight="SemiBold" Foreground="{Binding Accent}" Text="{Binding Value}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{StaticResource StatusBarBrush}" BorderBrush="{StaticResource StatusBarEdgeBrush}" BorderThickness="1,1,0,0">
      <ItemsControl ItemsSource="{Binding CurrentStatusStripItems}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource StatusStripCellStyle}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,6,0" Foreground="{StaticResource MutedBrush}" Text="{Binding Label}" />
                <TextBlock FontWeight="SemiBold" Text="{Binding Value}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <ContentControl Margin="8" Content="{Binding CurrentWorkspace}" />
  </DockPanel>
</Fluent:RibbonWindow>
