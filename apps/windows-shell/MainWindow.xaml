<Window
    x:Class="JanLabel.WindowsShell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{Binding WindowTitle}"
    Width="1760"
    Height="1040"
    MinWidth="1520"
    MinHeight="920"
    WindowStartupLocation="CenterScreen"
    Background="#D9DEE5"
    FontFamily="Segoe UI">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Views/CommonTemplates.xaml" />
        <ResourceDictionary Source="Views/HomeWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/DesignerWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/PrintConsoleWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/BatchJobsWorkspaceTemplates.xaml" />
        <ResourceDictionary Source="Views/HistoryWorkspaceTemplates.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top" Background="{StaticResource ChromeBrush}" BorderBrush="#BCC7D2" BorderThickness="0,0,0,1">
      <Grid Margin="8,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource MenuButtonStyle}" Content="File" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Edit" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="View" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Layout" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Data Sources" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Tools" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Administration" />
          <Button Style="{StaticResource MenuButtonStyle}" Content="Help" />
        </StackPanel>
        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
          <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding WindowTitle}" />
          <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding WorkspaceTagline}" />
        </StackPanel>
        <ItemsControl Grid.Column="2" ItemsSource="{Binding CurrentHeaderActions}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Margin="0,0,6,0" Padding="12,6" Content="{Binding}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top" Background="{StaticResource RibbonBrush}" BorderBrush="#BCC7D2" BorderThickness="0,0,0,1">
      <Grid Margin="8,8,8,6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ListBox
            Grid.Row="0"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Modules}"
            SelectedItem="{Binding SelectedModule}"
            ItemContainerStyle="{StaticResource SelectableItemStyle}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Width="210">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                  <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Description}" />
                </StackPanel>
                <TextBlock Grid.Column="1" Foreground="#235FA9" FontWeight="SemiBold" Text="{Binding Badge}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding CurrentRibbonGroups}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Width="230" Margin="0,0,8,0" Padding="10" Background="#FCFDFE" BorderBrush="#B9C4CF" BorderThickness="1">
                <StackPanel>
                  <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Title}" />
                  <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Commands}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Margin="0,0,6,6" Padding="10,8" MinWidth="100" Content="{Binding}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <ContentControl Margin="8" Content="{Binding CurrentWorkspace}" />
  </DockPanel>
</Window>
